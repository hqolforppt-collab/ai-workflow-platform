<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="definitions_DEC-001" name="Approval Routing" namespace="http://flowable.org/dmn">
  <decision id="DEC-001" name="Approval Routing">
    <decisionTable id="DEC-001-table" hitPolicy="FIRST">
      <input id="input1" label="Invoice amount (minor units)">
        <inputExpression id="input1_expr" typeRef="number">
          <text>gross_minor</text>
        </inputExpression>
      </input>
      <input id="input2" label="Department">
        <inputExpression id="input2_expr" typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>
      <input id="input3" label="Vendor risk">
        <inputExpression id="input3_expr" typeRef="string">
          <text>vendor_risk</text>
        </inputExpression>
      </input>
      <output id="output1" label="Approver role" name="approver-role" typeRef="string"/>
      <output id="output2" label="Requires four-eyes" name="requires-four-eyes" typeRef="boolean"/>
      <rule id="R1">
        <description>High-risk vendor at or above 50,000 EUR: CFO plus four-eyes</description>
        <inputEntry><text>&gt;= 5000000</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>"ROLE-CFO"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
      <rule id="R2">
        <description>Any invoice at or above the 50,000 EUR large-invoice threshold: CFO plus four-eyes (ASM-001)</description>
        <inputEntry><text>&gt;= 5000000</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"ROLE-CFO"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
      <rule id="R3">
        <description>High-risk vendor below threshold: manager plus four-eyes</description>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>"ROLE-APPROVER"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
      <rule id="R4">
        <description>10,000 to 50,000 EUR standard-risk: single manager approval</description>
        <inputEntry><text>&gt;= 1000000</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"ROLE-APPROVER"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
      <rule id="R5">
        <description>Below 10,000 EUR standard-risk: single team-lead approval</description>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"ROLE-APPROVER"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
