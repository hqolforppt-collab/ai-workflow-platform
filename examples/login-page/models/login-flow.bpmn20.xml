<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://ai-workflow-platform/examples/login-page">
  <!--
    Flowable-importable BPMN 2.0 rendering of examples/login-page/models/login-flow.bpmn
    (the canonical AWP model). Round-tripped in CI by .github/workflows/bpmn-roundtrip.yml
    to prove the platform's BPMN output is engine-valid, not just internal pseudo-YAML.
    Every step id in the canonical YAML model exists as a flow element here; the
    sync is enforced by scripts/bpmn-roundtrip.mjs.
  -->
  <process id="login-flow" name="User Login Process" isExecutable="true">
    <documentation>Handles credential validation, authentication, session creation, and audit logging, including error paths for invalid credentials, rate limiting, and account lockout.</documentation>

    <startEvent id="start" name="User submits login form" />

    <userTask id="validate_input" name="Validate Input" flowable:assignee="${initiator}">
      <documentation>Validate email format and password length.</documentation>
    </userTask>

    <exclusiveGateway id="input_valid_gw" name="Input valid?" />

    <serviceTask id="user_lookup" name="User Lookup" flowable:expression="${authService.lookupUser(email)}">
      <documentation>Query database for user by email.</documentation>
    </serviceTask>

    <exclusiveGateway id="user_found_gw" name="User found?" />

    <serviceTask id="password_verify" name="Password Verify" flowable:expression="${authService.verifyPassword(user, password)}">
      <documentation>Compare password hash using bcrypt.</documentation>
    </serviceTask>

    <exclusiveGateway id="password_match_gw" name="Password match?" />

    <exclusiveGateway id="check_account_status" name="Account active and not locked?" />

    <exclusiveGateway id="check_mfa" name="MFA enabled?" />

    <subProcess id="mfa_challenge" name="MFA Challenge">
      <documentation>Execute MFA verification subprocess.</documentation>
      <startEvent id="mfa_start" name="MFA challenge issued" />
      <userTask id="mfa_verify" name="Verify MFA Code" flowable:assignee="${initiator}">
        <documentation>User submits TOTP / WebAuthn / SMS code.</documentation>
      </userTask>
      <exclusiveGateway id="mfa_result_gw" name="MFA code valid?" />
      <endEvent id="mfa_success_end" name="MFA verified" />
      <endEvent id="mfa_failure_end" name="MFA failed">
        <errorEventDefinition errorRef="ERR_MFA_FAILED" />
      </endEvent>
      <sequenceFlow id="f_mfa_start_verify" sourceRef="mfa_start" targetRef="mfa_verify" />
      <sequenceFlow id="f_mfa_verify_gw" sourceRef="mfa_verify" targetRef="mfa_result_gw" />
      <sequenceFlow id="f_mfa_valid" sourceRef="mfa_result_gw" targetRef="mfa_success_end">
        <conditionExpression xsi:type="tFormalExpression">${mfaValid == true}</conditionExpression>
      </sequenceFlow>
      <sequenceFlow id="f_mfa_invalid" sourceRef="mfa_result_gw" targetRef="mfa_failure_end">
        <conditionExpression xsi:type="tFormalExpression">${mfaValid == false}</conditionExpression>
      </sequenceFlow>
    </subProcess>

    <boundaryEvent id="mfa_failed_boundary" name="MFA failure" attachedToRef="mfa_challenge">
      <errorEventDefinition errorRef="ERR_MFA_FAILED" />
    </boundaryEvent>

    <serviceTask id="session_create" name="Session Create" flowable:expression="${authService.createSession(user)}">
      <documentation>Generate JWT (HS256) token and create session, expires in 24 hours.</documentation>
    </serviceTask>

    <serviceTask id="set_cookie" name="Set Cookie" flowable:expression="${authService.setCookie(token)}">
      <documentation>Set HttpOnly, Secure, SameSite=Strict cookie.</documentation>
    </serviceTask>

    <serviceTask id="audit_log" name="Audit Log" flowable:expression="${auditService.logSuccess(user, request)}">
      <documentation>Log successful login (user_id, IP, user-agent, timestamp).</documentation>
    </serviceTask>

    <endEvent id="success" name="200 OK + session info" />

    <!-- Error path: failed-password handling -->
    <serviceTask id="error_invalid_password" name="Handle Invalid Password" flowable:expression="${authService.recordFailedAttempt(email)}">
      <documentation>Increment failed attempt counter and check rate limit.</documentation>
    </serviceTask>

    <exclusiveGateway id="rate_limit_gw" name="Under rate limit?" />

    <serviceTask id="audit_log_failure" name="Log Failed Attempt" flowable:expression="${auditService.logFailure(email, request)}">
      <documentation>Log failed login attempt (email, IP, reason).</documentation>
    </serviceTask>

    <endEvent id="error_invalid_input" name="400 Bad Request">
      <errorEventDefinition errorRef="ERR_INVALID_INPUT" />
    </endEvent>
    <endEvent id="error_user_not_found" name="401 Unauthorized (user not found)">
      <errorEventDefinition errorRef="ERR_UNAUTHORIZED" />
    </endEvent>
    <endEvent id="error_invalid_credentials" name="401 Unauthorized (invalid credentials)">
      <errorEventDefinition errorRef="ERR_UNAUTHORIZED" />
    </endEvent>
    <endEvent id="error_rate_limit" name="429 Too Many Requests">
      <errorEventDefinition errorRef="ERR_RATE_LIMIT" />
    </endEvent>
    <endEvent id="error_account_locked" name="403 Forbidden (locked)">
      <errorEventDefinition errorRef="ERR_FORBIDDEN" />
    </endEvent>
    <endEvent id="error_account_suspended" name="403 Forbidden (suspended)">
      <errorEventDefinition errorRef="ERR_FORBIDDEN" />
    </endEvent>
    <endEvent id="error_mfa_failed" name="401 Unauthorized (MFA failed)">
      <errorEventDefinition errorRef="ERR_UNAUTHORIZED" />
    </endEvent>

    <!-- Sequence flows -->
    <sequenceFlow id="f_start_validate" sourceRef="start" targetRef="validate_input" />
    <sequenceFlow id="f_validate_gw" sourceRef="validate_input" targetRef="input_valid_gw" />
    <sequenceFlow id="f_input_valid" sourceRef="input_valid_gw" targetRef="user_lookup">
      <conditionExpression xsi:type="tFormalExpression">${inputValid == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_input_invalid" sourceRef="input_valid_gw" targetRef="error_invalid_input">
      <conditionExpression xsi:type="tFormalExpression">${inputValid == false}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="f_lookup_gw" sourceRef="user_lookup" targetRef="user_found_gw" />
    <sequenceFlow id="f_user_found" sourceRef="user_found_gw" targetRef="password_verify">
      <conditionExpression xsi:type="tFormalExpression">${userFound == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_user_not_found" sourceRef="user_found_gw" targetRef="error_user_not_found">
      <conditionExpression xsi:type="tFormalExpression">${userFound == false}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="f_verify_gw" sourceRef="password_verify" targetRef="password_match_gw" />
    <sequenceFlow id="f_password_match" sourceRef="password_match_gw" targetRef="check_account_status">
      <conditionExpression xsi:type="tFormalExpression">${passwordMatch == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_password_mismatch" sourceRef="password_match_gw" targetRef="error_invalid_password">
      <conditionExpression xsi:type="tFormalExpression">${passwordMatch == false}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="f_invalid_password_gw" sourceRef="error_invalid_password" targetRef="rate_limit_gw" />
    <sequenceFlow id="f_under_limit" sourceRef="rate_limit_gw" targetRef="audit_log_failure">
      <conditionExpression xsi:type="tFormalExpression">${underLimit == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_rate_limited" sourceRef="rate_limit_gw" targetRef="error_rate_limit">
      <conditionExpression xsi:type="tFormalExpression">${underLimit == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_failure_logged" sourceRef="audit_log_failure" targetRef="error_invalid_credentials" />

    <sequenceFlow id="f_status_active" sourceRef="check_account_status" targetRef="check_mfa">
      <conditionExpression xsi:type="tFormalExpression">${accountStatus == 'active'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_status_locked" sourceRef="check_account_status" targetRef="error_account_locked">
      <conditionExpression xsi:type="tFormalExpression">${accountStatus == 'locked'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_status_suspended" sourceRef="check_account_status" targetRef="error_account_suspended">
      <conditionExpression xsi:type="tFormalExpression">${accountStatus == 'suspended'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="f_mfa_no" sourceRef="check_mfa" targetRef="session_create">
      <conditionExpression xsi:type="tFormalExpression">${mfaEnabled == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_mfa_yes" sourceRef="check_mfa" targetRef="mfa_challenge">
      <conditionExpression xsi:type="tFormalExpression">${mfaEnabled == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f_mfa_done" sourceRef="mfa_challenge" targetRef="session_create" />
    <sequenceFlow id="f_mfa_failed" sourceRef="mfa_failed_boundary" targetRef="error_mfa_failed" />

    <sequenceFlow id="f_session_cookie" sourceRef="session_create" targetRef="set_cookie" />
    <sequenceFlow id="f_cookie_audit" sourceRef="set_cookie" targetRef="audit_log" />
    <sequenceFlow id="f_audit_success" sourceRef="audit_log" targetRef="success" />
  </process>

  <error id="ERR_INVALID_INPUT" errorCode="400" />
  <error id="ERR_UNAUTHORIZED" errorCode="401" />
  <error id="ERR_RATE_LIMIT" errorCode="429" />
  <error id="ERR_FORBIDDEN" errorCode="403" />
  <error id="ERR_MFA_FAILED" errorCode="MFA_FAILED" />
</definitions>
